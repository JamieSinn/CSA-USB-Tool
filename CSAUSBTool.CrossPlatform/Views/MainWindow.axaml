<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSAUSBTool.CrossPlatform.ViewModels"
        xmlns:models="using:CSAUSBTool.CrossPlatform.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="800"
        x:Class="CSAUSBTool.CrossPlatform.Views.MainWindow"
        Icon="/Assets/reuven.ico"
        Title="CSA USB Tool"
        x:DataType="vm:MainWindowViewModel"
        SizeToContent="Manual">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="12">
    <TextBlock Grid.Row="0" Text="{Binding StatusText}" Margin="0,0,0,8" TextWrapping="Wrap" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Step 1: Fetch JSON List" Click="FetchJsonList_OnClick" />
      <ComboBox Width="450"
                ItemsSource="{Binding JsonFiles}"
                SelectedItem="{Binding SelectedJsonFile}" />
      <Button Content="Step 2: Load Selected JSON" Click="LoadSelectedJson_OnClick" />
    </StackPanel>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock VerticalAlignment="Center" Text="Step 3: Select by tag" />
      <ComboBox Width="220"
                ItemsSource="{Binding TagOptions}"
                SelectedItem="{Binding SelectedTag}" />
      <Button Content="Toggle Tag" Click="ToggleTag_OnClick" />
      <Button Content="Select All" Click="SelectAll_OnClick" />
      <Button Content="Deselect All" Click="DeselectAll_OnClick" />
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Step 4: Select Folder" Click="SelectFolder_OnClick" />
      <TextBox Width="650" IsReadOnly="True" Text="{Binding DownloadFolder}" />
    </StackPanel>

    <ListBox Grid.Row="4" ItemsSource="{Binding SoftwareItems}" Margin="0,0,0,8">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:ControlSystemSoftware">
          <Border BorderThickness="0,0,0,1" BorderBrush="#33444444" Padding="4">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="*,Auto">
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsChecked}"
                          IsEnabled="{Binding IsSelectable}"
                          Content="{Binding DisplayText}" />
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" />
              </Grid>
              <ProgressBar Minimum="0"
                           Maximum="100"
                           Value="{Binding DownloadProgress}"
                           ShowProgressText="True" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Step 5: Download Selected" Click="DownloadSelected_OnClick" IsEnabled="{Binding CanDownload}" />
      <Button Content="Step 6: Verify MD5" Click="VerifyMd5_OnClick" IsEnabled="{Binding CanVerify}" />
      <Button Content="Cancel" Click="Cancel_OnClick" />
      <TextBlock VerticalAlignment="Center" Text="Max Parallel" />
      <ComboBox Width="80"
                ItemsSource="{Binding MaxParallelOptions}"
                SelectedItem="{Binding MaxParallelDownloads}" />
    </StackPanel>

    <TextBlock Grid.Row="6" Text="Tip: Tag toggle does not filter list. It toggles checkboxes on matching items." FontSize="12" Opacity="0.75" />
  </Grid>
</Window>
